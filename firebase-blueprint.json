{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name"]
    },
    "Stage": {
      "title": "Stage",
      "description": "Pipeline stage definition",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "color": { "type": "string" },
        "order": { "type": "integer" }
      },
      "required": ["name", "color", "order"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Lead information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "company": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "website": { "type": "string" },
        "segment": { "type": "string" },
        "location": { "type": "string" },
        "size": { "type": "string" },
        "cnpj": { "type": "string" },
        "stage_id": { "type": "string" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "last_interaction": { "type": "string", "format": "date-time" },
        "owner_id": { "type": "string" }
      },
      "required": ["name", "stage_id", "owner_id"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "History of interaction with a lead",
      "type": "object",
      "properties": {
        "lead_id": { "type": "string" },
        "type": { "type": "string", "enum": ["call", "email", "whatsapp", "meeting", "note"] },
        "content": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["lead_id", "type", "content"]
    },
    "Task": {
      "title": "Task",
      "description": "Task related to a lead",
      "type": "object",
      "properties": {
        "lead_id": { "type": "string" },
        "title": { "type": "string" },
        "due_date": { "type": "string", "format": "date-time" },
        "completed": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["lead_id", "title"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Application settings",
      "type": "object",
      "properties": {
        "company_name": { "type": "string" },
        "currency": { "type": "string" },
        "owner_id": { "type": "string" }
      },
      "required": ["owner_id"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/stages/{stageId}": {
      "schema": "Stage",
      "description": "Pipeline stages"
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Leads"
    },
    "/interactions/{interactionId}": {
      "schema": "Interaction",
      "description": "Lead interactions"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Lead tasks"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "App settings"
    }
  }
}
